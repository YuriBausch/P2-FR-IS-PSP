    "slot_size": 116,
    "data_size": 112,
    "nom_orig": "Yukino",
    "texte_orig": "Not[SP]so![SP]Is[SP]it[SP]time[SP]for[SP]me[SP]to[SP]bust[SP]this[SP]out?",
