    "data_size": 108,
    "nom_orig": "Ginko",
    "texte_orig": "Ho[SP]Oi[SP]Dik![1205][001E][SP][U+1113]'s[SP]so[SP]cute\nwhen[SP]he's[SP]asleep!",
    "nom_fr": "Ginko",
    "texte_fr": "Oh wow![1205][001E] [U+1113] est trop mignon\nquand il dort!"
