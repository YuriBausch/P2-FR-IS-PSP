    "data_size": 170,
    "nom_orig": "Maya",
    "texte_orig": "Nope![SP]We[SP]were[SP]the[SP]ones[SP]talking[SP]about[SP]a\ncompass.[SP]Try[SP]and[SP]think[SP]back,[SP][U+1113]-kun.",
