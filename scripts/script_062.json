    "offset": 315812,
    "slot_size": 226,
    "data_size": 222,
    "nom_orig": "Maya",
    "texte_orig": "Even[SP]if[SP]it[SP]is,[SP]the[SP]location[SP]is[SP]written\npretty[SP]clearly[SP]here.[SP]He[SP]wants[SP]to[SP]settle\nthings[SP]with[SP]us[SP]too...",
