  {
    "id": 1,
    "offset": 167938,
    "slot_size": 256,
    "data_size": 252,
    "nom_orig": "Yukino",
    "texte_orig": "Well,[SP]looks[SP]like[SP]everyone's[SP]feeling[SP]much\nbetter.[SP]Should[SP]we[SP]start[SP]thinking[SP]seriously\nabout[SP]how[SP]to[SP]get[SP]out[SP]of[SP]here?",
    "nom_fr": "Yukino",
    "texte_fr": "Bon, tout le monde a l'air de se sentir\nmieux. On devrait sérieusement\n trouver un moyen de sortir d'ici, non?"
